generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orgMemberships OrgMember[]
  assignedLeads  Lead[]      @relation("AssignedLeads")
  createdLeads   Lead[]      @relation("CreatedLeads")
  campaigns      Campaign[]
  deals          Deal[]
  notes          Note[]
  activities     Activity[]
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  logo        String?
  website     String?
  industry    String?
  plan        OrgPlan     @default(FREE)
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  members     OrgMember[]
  leads       Lead[]
  campaigns   Campaign[]
  deals       Deal[]
  contracts   Contract[]
  integrations Integration[]
  webhooks    Webhook[]
  sequences   Sequence[]
  breeds      Breed[]
  birds       Bird[]
  flocks      Flock[]
  hatchRecords HatchRecord[]
  eggRecords  EggRecord[]
  listings    Listing[]
  farmOrders  FarmOrder[]
  farmCustomers FarmCustomer[]
  healthRecords HealthRecord[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum OrgPlan {
  FREE
  STARTER
  GROWTH
  SCALE
  ENTERPRISE
}

model OrgMember {
  id     String    @id @default(cuid())
  userId String
  orgId  String
  role   OrgMemberRole @default(MEMBER)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Lead {
  id              String      @id @default(cuid())
  orgId           String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  company         String?
  title           String?
  linkedinUrl     String?
  website         String?
  industry        String?
  employeeCount   Int?
  annualRevenue   Float?
  location        String?
  country         String?
  source          LeadSource  @default(MANUAL)
  status          LeadStatus  @default(NEW)
  score           Int         @default(0)
  tags            String[]
  customFields    Json?
  apolloId        String?     @unique
  assignedToId    String?
  createdById     String?
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedTo      User?        @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdBy       User?        @relation("CreatedLeads", fields: [createdById], references: [id])
  deals           Deal[]
  messages        Message[]
  notes           Note[]
  activities      Activity[]
  campaignEnrollments CampaignEnrollment[]
  sequenceEnrollments SequenceEnrollment[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([orgId])
  @@index([email])
  @@index([status])
}

enum LeadSource {
  MANUAL
  APOLLO
  IMPORT
  FORM
  REFERRAL
  LINKEDIN
  WEBSITE
  ZAPIER
  API
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  NURTURING
  CONVERTED
  LOST
  ARCHIVED
}

model Campaign {
  id          String         @id @default(cuid())
  orgId       String
  name        String
  description String?
  type        CampaignType
  status      CampaignStatus @default(DRAFT)
  subject     String?
  body        String?        @db.Text
  fromName    String?
  fromEmail   String?
  scheduledAt DateTime?
  sentAt      DateTime?
  createdById String?
  org         Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy   User?          @relation(fields: [createdById], references: [id])
  enrollments CampaignEnrollment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([orgId])
  @@index([status])
}

enum CampaignType {
  EMAIL
  SMS
  LINKEDIN
  MULTI_CHANNEL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  CANCELLED
}

model CampaignEnrollment {
  id          String    @id @default(cuid())
  campaignId  String
  leadId      String
  status      EnrollmentStatus @default(PENDING)
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  repliedAt   DateTime?
  bouncedAt   DateTime?
  unsubscribedAt DateTime?
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
}

enum EnrollmentStatus {
  PENDING
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
  FAILED
}

model Sequence {
  id          String    @id @default(cuid())
  orgId       String
  apolloId    String?   @unique
  name        String
  status      String    @default("active")
  steps       SequenceStep[]
  enrollments SequenceEnrollment[]
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SequenceStep {
  id           String    @id @default(cuid())
  sequenceId   String
  type         String
  delayDays    Int       @default(0)
  subject      String?
  body         String?   @db.Text
  position     Int
  sequence     Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
}

model SequenceEnrollment {
  id          String    @id @default(cuid())
  sequenceId  String
  leadId      String
  status      String    @default("active")
  currentStep Int       @default(0)
  enrolledAt  DateTime  @default(now())
  sequence    Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
}

model Deal {
  id          String      @id @default(cuid())
  orgId       String
  leadId      String?
  ownerId     String?
  title       String
  value       Float       @default(0)
  currency    String      @default("USD")
  stage       DealStage   @default(PROSPECTING)
  probability Int         @default(0)
  expectedCloseDate DateTime?
  closedAt    DateTime?
  notes       String?     @db.Text
  customFields Json?
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead        Lead?        @relation(fields: [leadId], references: [id])
  owner       User?        @relation(fields: [ownerId], references: [id])
  activities  Activity[]
  contract    Contract?
  stripeInvoiceId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([orgId])
  @@index([stage])
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

model Contract {
  id              String          @id @default(cuid())
  orgId           String
  dealId          String?         @unique
  docusignEnvelopeId String?      @unique
  title           String
  status          ContractStatus  @default(DRAFT)
  signerName      String?
  signerEmail     String?
  sentAt          DateTime?
  viewedAt        DateTime?
  signedAt        DateTime?
  declinedAt      DateTime?
  voidedAt        DateTime?
  expiresAt       DateTime?
  documentUrl     String?
  org             Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deal            Deal?           @relation(fields: [dealId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([orgId])
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  DECLINED
  VOIDED
  EXPIRED
}

model Message {
  id          String      @id @default(cuid())
  leadId      String?
  orgId       String?
  type        MessageType
  direction   MessageDirection @default(OUTBOUND)
  status      MessageStatus @default(PENDING)
  subject     String?
  body        String?     @db.Text
  fromAddress String?
  toAddress   String?
  twilioSid   String?     @unique
  gmailMessageId String?  @unique
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  failedAt    DateTime?
  errorMessage String?
  lead        Lead?       @relation(fields: [leadId], references: [id])
  createdAt   DateTime    @default(now())

  @@index([leadId])
  @@index([type])
}

enum MessageType {
  EMAIL
  SMS
  CALL
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  BOUNCED
}

model Payment {
  id              String        @id @default(cuid())
  orgId           String?
  stripePaymentId String?       @unique
  stripeInvoiceId String?       @unique
  amount          Float
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  description     String?
  customerEmail   String?
  metadata        Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  @@index([orgId])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

model Integration {
  id          String     @id @default(cuid())
  orgId       String
  type        IntegrationType
  name        String
  isActive    Boolean    @default(false)
  config      Json?
  encryptedCredentials String? @db.Text
  lastSyncAt  DateTime?
  errorMessage String?
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([orgId, type])
}

enum IntegrationType {
  APOLLO
  STRIPE
  TWILIO
  SLACK
  GMAIL
  DOCUSIGN
  POSTHOG
  SENTRY
  ZAPIER
  FIGMA
}

model Webhook {
  id          String    @id @default(cuid())
  orgId       String
  url         String
  secret      String
  events      String[]
  isActive    Boolean   @default(true)
  lastTriggeredAt DateTime?
  failureCount Int      @default(0)
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId])
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  authorId  String?
  content   String   @db.Text
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String?
  dealId      String?
  userId      String?
  type        ActivityType
  description String?      @db.Text
  metadata    Json?
  lead        Lead?        @relation(fields: [leadId], references: [id])
  deal        Deal?        @relation(fields: [dealId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())

  @@index([leadId])
  @@index([dealId])
}

enum ActivityType {
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_STATUS_CHANGED
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_REPLIED
  SMS_SENT
  SMS_RECEIVED
  CALL_MADE
  CALL_RECEIVED
  DEAL_CREATED
  DEAL_STAGE_CHANGED
  DEAL_WON
  DEAL_LOST
  CONTRACT_SENT
  CONTRACT_SIGNED
  NOTE_ADDED
  SEQUENCE_ENROLLED
  SEQUENCE_COMPLETED
  PAYMENT_RECEIVED
}

// ─── Farm / Poultry Models ────────────────────────────────────────────────────

enum Species {
  CHICKEN
  DUCK
  GOOSE
  TURKEY
  GUINEA_FOWL
  QUAIL
  OTHER
}

model Breed {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  species     Species
  description String?   @db.Text
  color       String?
  eggColor    String?
  temperament String?
  matureWeightLbs Float?
  isRare      Boolean   @default(false)
  isAvailable Boolean   @default(true)
  imageUrls   String[]
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  birds       Bird[]
  listings    Listing[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([orgId, name])
  @@index([orgId])
}

enum BirdSex {
  MALE
  FEMALE
  UNKNOWN
}

enum BirdStatus {
  ACTIVE
  FOR_SALE
  SOLD
  DECEASED
  GIVEN_AWAY
  INCUBATING
}

model Bird {
  id           String      @id @default(cuid())
  orgId        String
  breedId      String?
  flockId      String?
  bandNumber   String?
  name         String?
  sex          BirdSex     @default(UNKNOWN)
  status       BirdStatus  @default(ACTIVE)
  hatchDate    DateTime?
  acquiredDate DateTime?
  acquiredFrom String?
  notes        String?     @db.Text
  imageUrls    String[]
  weight       Float?
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  breed        Breed?       @relation(fields: [breedId], references: [id])
  flock        Flock?       @relation(fields: [flockId], references: [id])
  healthRecords HealthRecord[]
  eggRecords   EggRecord[]
  saleItems    SaleItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([orgId])
  @@index([breedId])
  @@index([status])
}

enum FlockPurpose {
  BREEDING
  LAYING
  MEAT
  SHOW
  PET
}

model Flock {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  description String?
  location    String?
  purpose     FlockPurpose @default(BREEDING)
  birds       Bird[]
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId])
}

enum HatchStatus {
  INCUBATING
  LOCKDOWN
  HATCHING
  COMPLETE
  FAILED
}

model HatchRecord {
  id              String        @id @default(cuid())
  orgId           String
  breedId         String?
  batchName       String
  species         Species       @default(CHICKEN)
  eggsSet         Int
  eggsLaid        Int?
  settingDate     DateTime
  expectedHatchDate DateTime
  actualHatchDate DateTime?
  eggsHatched     Int?
  eggsUnhatched   Int?
  eggsFertile     Int?
  chicksSurvived  Int?
  incubatorTemp   Float?
  incubatorHumidity Float?
  notes           String?       @db.Text
  status          HatchStatus   @default(INCUBATING)
  org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orgId])
}

enum EggSize {
  PEEWEE
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
  JUMBO
}

enum EggPurpose {
  HATCHING
  EATING
  SELLING
}

model EggRecord {
  id          String    @id @default(cuid())
  orgId       String
  birdId      String?
  breedId     String?
  collectedAt DateTime  @default(now())
  count       Int       @default(1)
  color       String?
  size        EggSize?
  purpose     EggPurpose @default(HATCHING)
  notes       String?
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bird        Bird?       @relation(fields: [birdId], references: [id])

  @@index([orgId])
}

enum AgeType {
  HATCHING_EGG
  DAY_OLD_CHICK
  STARTED_PULLET
  JUVENILE
  ADULT
  BREEDING_PAIR
  BREEDING_TRIO
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD_OUT
  PAUSED
  ARCHIVED
}

model Listing {
  id           String        @id @default(cuid())
  orgId        String
  breedId      String?
  title        String
  description  String?       @db.Text
  species      Species       @default(CHICKEN)
  ageType      AgeType       @default(DAY_OLD_CHICK)
  sex          BirdSex?
  quantity     Int           @default(1)
  quantityAvail Int          @default(1)
  priceEach    Float
  status       ListingStatus @default(ACTIVE)
  imageUrls    String[]
  shipsTo      String[]
  localPickup  Boolean       @default(true)
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  breed        Breed?        @relation(fields: [breedId], references: [id])
  saleItems    SaleItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([orgId])
  @@index([status])
}

enum OrderStatus {
  PENDING
  DEPOSIT_PAID
  PAID
  READY
  SHIPPED
  PICKED_UP
  CANCELLED
  REFUNDED
}

model FarmOrder {
  id            String      @id @default(cuid())
  orgId         String
  customerId    String?
  orderNumber   String      @unique
  status        OrderStatus @default(PENDING)
  totalAmount   Float
  depositAmount Float       @default(0)
  depositPaid   Boolean     @default(false)
  notes         String?     @db.Text
  shippingName  String?
  shippingEmail String?
  shippingPhone String?
  shippingAddr  String?
  pickupDate    DateTime?
  shippedAt     DateTime?
  stripePaymentId String?
  items         SaleItem[]
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer      FarmCustomer? @relation(fields: [customerId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([orgId])
  @@index([status])
}

model SaleItem {
  id        String    @id @default(cuid())
  orderId   String
  listingId String?
  birdId    String?
  description String
  quantity  Int       @default(1)
  unitPrice Float
  order     FarmOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing   Listing?  @relation(fields: [listingId], references: [id])
  bird      Bird?     @relation(fields: [birdId], references: [id])
}

model FarmCustomer {
  id        String      @id @default(cuid())
  orgId     String
  name      String
  email     String?
  phone     String?
  location  String?
  notes     String?     @db.Text
  orders    FarmOrder[]
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([orgId])
}

enum HealthRecordType {
  VACCINATION
  TREATMENT
  OBSERVATION
  INJURY
  ILLNESS
  DEATH
  CHECKUP
}

model HealthRecord {
  id          String    @id @default(cuid())
  orgId       String
  birdId      String
  type        HealthRecordType
  date        DateTime
  description String    @db.Text
  treatment   String?
  vetName     String?
  cost        Float?
  followUpDate DateTime?
  bird        Bird      @relation(fields: [birdId], references: [id], onDelete: Cascade)
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([birdId])
}
